# LLM
# Anthropic (默认)
ANTHROPIC_API_KEY=sk-ant-xxx
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# 通用 API Key（优先级高于 ANTHROPIC_API_KEY，适用于 OpenAI 协议厂商）
# LLM_API_KEY=sk-xxx

# 自定义 Base URL（设置后自动切换为 OpenAI 协议，可对接任意兼容厂商）
# 示例：OpenAI: https://api.openai.com/v1
#       DeepSeek: https://api.deepseek.com/v1
#       通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# 可观测性（可选）
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ads-data-agent

# 服务
SECRET_KEY=change-me-in-production

# 企业内网 SSL 自签证书拦截（Huawei 内网 / 公司 HTTPS 代理）：
# bundle 启动报 'SSL: CERTIFICATE_VERIFY_FAILED' 时打开下面这行：
# LLM_VERIFY_SSL=false

# 公司 HTTP_PROXY 环境变量自动被 httpx 读取，但代理转发 LLM 请求容易 504 超时
# （特别是请求大、上下文长时）。LLM endpoint 在内网时本来就不该走外网代理。
# 报 'httpx.ProxyError: 504 Gateway Time-out' 时打开下面这行：
# LLM_NO_PROXY=1
