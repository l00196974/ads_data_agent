.env
.env.*
!.env.example
data/
*.db
*.sqlite
__pycache__/
*.pyc
.venv/
node_modules/
dist/
*.egg-info/

# 打包工件：下载缓存（Node + Python portable archives, get-pip.py）+ PyInstaller 中间产物
# 缓存可重复下载，PyInstaller 中间产物每次 build 重生
build/cache/
build/_pyi-build/
build/_pyi-spec/

# Logs
*.log

# Playwright / e2e test artifacts
.playwright-mcp/
e2e-test-login
login-page-*
chat-*.png
exec-*.png
e2e-*.png
prefs-*.png
subagent-*.png
thinking-*.png
ui-*.png
bundle-*.png
chart-inline.png
scroll-top.png

# Benchmark / one-off probe scripts（临时验证用，不入仓）
bench_result.jsonl
scripts/benchmark_*.py
scripts/probe_*.py

# Memory / hook plugin runtime data
.remember/

# Windows Mark-of-the-Web sidecar files
*:Zone.Identifier
*Zone.Identifier

# Claude Code per-machine settings (share .claude/settings.json, ignore .local)
.claude/settings.local.json

# VSCode 工作区配置：混含个人偏好（字体/主题）和安全姿态（如 Claude Code 的
# allowDangerouslySkipPermissions）。安全策略让每个开发者自己选——不强加到仓库。
# 如果将来需要团队统一的代码风格设置（formatter / lint），单独 git add -f 加白名单。
.vscode/

# Eval outputs（每次跑都会变，靠 results.json.example 当模板）
benchmarks/*/results.json

# 框架不内置任何业务技能——skills/ 下的 skill 包都属于部署方维护的本地内容，
# git 不该追踪。如果你确实需要把某个 skill 纳入这份仓库管理，可以 git add -f 覆盖。
skills/*/

# 已入仓的 skill 内"实际配置"不入仓——避免 git pull 把别人的本地配置覆盖。
# 约定：每个实际配置都有同名 + .example 后缀的样例文件，新部署从 example 拷贝改名。
# 这里精确列举，避免 *.csv / *.json 之类通配误伤 skill 内的 schema / 元数据文件。
skills/metric-data-extractor/config.json
skills/metric-data-extractor/config/dimensions.csv
skills/metric-data-extractor/config/dimension-values.csv
skills/metric-data-extractor/config/metrics.csv

