benchmarks/*/results.json

# 框架不内置任何业务技能——skills/ 下的 skill 包都属于部署方维护的本地内容，
# git 不该追踪。如果你确实需要把某个 skill 纳入这份仓库管理，可以 git add -f 覆盖。
skills/*/

